# ---------------------------------------------------------
# Copia este ficheiro para ".env" e preenche com os teus dados.
# NUNCA envies o ficheiro ".env" real para o GitHub ou para o cliente.
# ---------------------------------------------------------

# Porta onde o servidor Express corre
PORT=4000

# Origem do teu frontend (para o CORS). Ex: http://localhost:5500 ou o domínio do site.
FRONTEND_ORIGIN=http://localhost:5500

# Segredo usado para assinar os tokens de sessão (JWT).
# Gera um valor aleatório forte, por exemplo com:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=troca_isto_por_um_segredo_bem_grande_e_aleatorio

# ---------------------------------------------------------
# Credenciais da API M-Pesa Moçambique (Vodacom M-Pesa OpenAPI)
# Obtêm-se registando-te como comerciante em:
# https://developer.mpesa.vm.co.mz
# ---------------------------------------------------------
MPESA_API_HOST=https://api.sandbox.vm.co.mz:18352
MPESA_API_KEY=a_tua_api_key_do_portal_mpesa
MPESA_PUBLIC_KEY=a_chave_publica_fornecida_pela_vodacom
MPESA_SERVICE_PROVIDER_CODE=171717
MPESA_ORIGIN=developer.mpesa.vm.co.mz
